{
	"name": "doriane-care-shop",
	"description": "A basic shop template that contains the logic for creating e-commerce front-ends",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"find": "set NODE_OPTIONS=--trace-warnings && next dev",
		"build": "next build",
		"build:vercel": "chmod u+x vercel-install.sh && ./vercel-install.sh && next build",
