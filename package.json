		"lint:biome": "biome lint",
		"format:biome": "biome format",
		"format:biome-fix": "biome format --write",
		"format": "pnpm run format:prettier && pnpm run format:biome",
		"format:prettier": "prettier --write ./**/*.{js,jsx,ts,tsx}"
	},
